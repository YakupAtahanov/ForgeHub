{
  "name": "forgehub",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently -n api,web -c cyan,magenta \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "npm run dev -w @forgehub/api",
    "dev:web": "npm run dev -w @forgehub/web",
    "db:push": "npm run db:push -w @forgehub/api",
    "db:generate": "npm run db:generate -w @forgehub/api"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  },
  "engines": {
    "node": ">=20"
  }
}
