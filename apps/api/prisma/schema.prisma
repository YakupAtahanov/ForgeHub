generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum RepoVisibility {
  PUBLIC
  PRIVATE
}

enum CollaboratorRole {
  READER
  WRITER
}

model User {
  id             String             @id @default(cuid())
  email          String             @unique
  passwordHash   String
  handle         String             @unique
  displayName    String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  repos          Repo[]
  collaborations RepoCollaborator[]
  pullRequests   PullRequest[]
}

model Repo {
  id            String             @id @default(cuid())
  name          String
  description   String?
  visibility    RepoVisibility     @default(PUBLIC)
  storageKey    String?            @unique
  ownerId       String
  owner         User               @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  collaborators     RepoCollaborator[]
  snapshots         Snapshot[]
  pullRequests      PullRequest[]
  protectedBranches ProtectedBranch[]

  @@unique([ownerId, name])
}

model RepoCollaborator {
  id        String           @id @default(cuid())
  repoId    String
  userId    String
  role      CollaboratorRole @default(READER)
  createdAt DateTime         @default(now())

  repo Repo @relation(fields: [repoId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([repoId, userId])
}

model Snapshot {
  id            String       @id @default(cuid())
  repoId        String
  label         String?
  sourceFile    String
  schemaVersion String       @default("0.1.0")
  createdAt     DateTime     @default(now())
  gitCommitSha  String?

  repo          Repo         @relation(fields: [repoId], references: [id], onDelete: Cascade)
  entities      Entity[]
  constraints   Constraint[]
}

model Entity {
  id             String       @id @default(cuid())
  snapshotId     String
  entityId       String
  parentEntityId String?
  kind           String
  name           String
  path           String
  posX           Float?
  posY           Float?
  posZ           Float?
  rotX           Float?
  rotY           Float?
  rotZ           Float?
  scaleX         Float?
  scaleY         Float?
  scaleZ         Float?
  attributes     String       @default("{}")
  renderRef      String?

  snapshot       Snapshot     @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  constraintsAsA Constraint[] @relation("ConstraintEntityA")
  constraintsAsB Constraint[] @relation("ConstraintEntityB")

  @@unique([snapshotId, entityId])
}

enum PRState {
  OPEN
  MERGED
  CLOSED
}

model PullRequest {
  id          String   @id @default(cuid())
  repoId      String
  number      Int
  title       String
  description String?
  fromBranch  String
  toBranch    String
  state       PRState  @default(OPEN)
  mergedAt    DateTime?
  authorId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  repo   Repo @relation(fields: [repoId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id])

  @@unique([repoId, number])
}

model ProtectedBranch {
  id     String @id @default(cuid())
  repoId String
  branch String

  repo Repo @relation(fields: [repoId], references: [id], onDelete: Cascade)

  @@unique([repoId, branch])
}

model Constraint {
  id            String   @id @default(cuid())
  snapshotId    String
  entityAId     String
  entityBId     String
  positionFixed Boolean  @default(true)
  rotationFixed Boolean  @default(true)
  createdAt     DateTime @default(now())

  snapshot Snapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  entityA  Entity   @relation("ConstraintEntityA", fields: [entityAId], references: [id], onDelete: Cascade)
  entityB  Entity   @relation("ConstraintEntityB", fields: [entityBId], references: [id], onDelete: Cascade)

  @@unique([snapshotId, entityAId, entityBId])
}
